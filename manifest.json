{
  "manifest_version": 3,
  "name": "OZON Brand Guard",
  "version": "1.5.0",
  "description": "Автоматическая защита брендов от подделок на OZON — подача жалоб на нарушителей",
  "default_locale": "ru",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://seller.ozon.ru/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://seller.ozon.ru/app/brand/sellers*"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://seller.ozon.ru/app/brand-products/*"],
      "js": ["content/content-products.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "options_page": "options/options.html"
}
