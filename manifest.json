{
  "manifest_version": 3,
  "name": "OZON Brand Guard",
  "version": "2.1.3",
  "description": "Автоматическая защита брендов от подделок на OZON — подача жалоб на нарушителей",
  "default_locale": "ru",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://seller.ozon.ru/*"
  ],

  "background": {
    "service_worker": "background/service-worker.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },

  "options_page": "options/options.html"
}
